FROM node:20-bookworm-slim

WORKDIR /app

# Install Python and OddsHarvester (required for direct odds scraping)
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    python3-pip \
    && pip install --no-cache-dir oddsharvester \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

COPY package*.json ./
COPY prisma ./prisma
RUN npm ci --include=dev

COPY . .

ENV NODE_ENV=production

CMD ["npm", "run", "worker:odds-refresh"]
