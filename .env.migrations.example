# Copy this to .env.migrations and fill in the values.
# .env.migrations is git-ignored — never commit it.
#
# HOW TO GET THESE VALUES
# -----------------------
# RAILWAY_TOKEN:
#   https://railway.app/settings/tokens → "New Token"
#
# RAILWAY_PROJECT_ID + RAILWAY_SERVICE_ID:
#   Open your Railway project → service → Settings → IDs section
#   (or run: railway status  after linking once with: railway link)
#
# RENDER_DATABASE_URL:
#   Render Dashboard → your Postgres service → "Connect" tab
#   → use "External Database URL"  (this is a DIRECT connection, not pgBouncer)
#   It looks like: postgres://user:pass@oregon-postgres.render.com/dbname

RAILWAY_TOKEN=""
RAILWAY_PROJECT_ID=""
RAILWAY_SERVICE_ID=""

RENDER_DATABASE_URL=""
