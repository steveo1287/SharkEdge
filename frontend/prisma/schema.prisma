  cumulativeProfit    Float                @default(0)
  metadataJson        Json?
  trendDefinition     SavedTrendDefinition @relation(fields: [trendDefinitionId], references: [id], onDelete: Cascade)
  event               Event                @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@unique([trendDefinitionId, eventId])
  @@index([eventId, matchedAt])
  @@index([trendDefinitionId, matchedAt])
  @@map("saved_trend_matches")
}

