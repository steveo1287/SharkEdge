  playerId            String?
  sportsbookId        String
  side                String
  lineValue           Float?
  offeredOddsAmerican Int
  fairOddsAmerican    Int?
  modelProb           Float
  noVigProb           Float?
  evPercent           Float
  kellyFull           Float?
  kellyHalf           Float?
  confidenceScore     Float?
  edgeScore           Float?
  flagsJson           Json
  modelRunId          String?
  expiresAt           DateTime?
  isActive            Boolean    @default(true)
  metadataJson        Json?
  createdAt           DateTime   @default(now())
  event               Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
