model SavedTrend {
  id        String      @id @default(cuid())
  userId    String
  name      String
  sport     SportCode
  queryJson Json
  archivedAt DateTime?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  definition SavedTrendDefinition?
  trendRuns TrendRun[]

  @@index([userId, sport])
  @@index([userId, archivedAt, updatedAt])
  @@map("saved_trends")
}

model TrendRun {
  id           String      @id @default(cuid())
  savedTrendId String?
  userId       String?
  queryJson    Json
  resultJson   Json
  createdAt    DateTime    @default(now())
  savedTrend   SavedTrend? @relation(fields: [savedTrendId], references: [id], onDelete: SetNull)
  user         User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([savedTrendId, createdAt])
  @@map("trend_runs")
}

model SavedTrendDefinition {
  id                 String               @id @default(cuid())
  savedTrendId       String?              @unique
  creatorId          String?
  name               String
  description        String?
  sport              SportCode
  league             String?
  betType            String
  filterConditionsJson Json
  isSystemGenerated  Boolean              @default(false)
  isUserCreated      Boolean              @default(true)
  isPublic           Boolean              @default(false)
  isPremium          Boolean              @default(false)
  currentStatsJson   Json?
  lastComputedAt     DateTime?
  savedTrend         SavedTrend?          @relation(fields: [savedTrendId], references: [id], onDelete: SetNull)
  creator            User?                @relation("SavedTrendDefinitionCreator", fields: [creatorId], references: [id], onDelete: SetNull)
  matches            SavedTrendMatch[]
  snapshots          SavedTrendSnapshot[]
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@index([sport, isSystemGenerated, updatedAt])
  @@index([league, betType, updatedAt])
  @@index([creatorId, updatedAt])
  @@map("saved_trend_definitions")
}

model SavedTrendMatch {
  id                  String               @id @default(cuid())
  trendDefinitionId   String
  eventId             String
  matchedAt           DateTime             @default(now())
