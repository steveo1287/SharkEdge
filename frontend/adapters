import type { GameCardView } from "@/lib/types/domain";

export type LeagueHubGame = {
  id: string;
  label: string;
  startTime: string;
  away: string;
  home: string;
  edgeScore: number;
  edgeLabel: string;
  href: string;
};

export type LeagueHubEdge = {
  gameId: string;
  selection: string;
  odds: number;
  ev: number | null;
  confidence: string;
  href: string;
};

export function adaptLeagueGames(games: GameCardView[]): LeagueHubGame[] {
  return games.map((g) => ({
    id: g.id,
    label: `${g.awayTeam.name} @ ${g.homeTeam.name}`,
    startTime: g.startTime,
    away: g.awayTeam.name,
    home: g.homeTeam.name,
    edgeScore: g.edgeScore.score,
    edgeLabel: g.edgeScore.label,
    href: g.detailHref ?? `/game/${g.id}`,
  }));
}

export function extractTopEdges(games: GameCardView[]): LeagueHubEdge[] {
  return games
    .flatMap((g) => {
      const signals = [
        g.spread,
        g.moneyline,
        g.total,
      ];

      return signals
        .filter((m) => m?.evProfile?.evPerUnit)
        .map((m) => ({
          gameId: g.id,
          selection: m.label,
          odds: m.bestOdds,
          ev: m.evProfile?.evPerUnit
            ? Number((m.evProfile.evPerUnit * 100).toFixed(2))
            : null,
          confidence: m.confidenceBand ?? "low",
          href: g.detailHref ?? `/game/${g.id}`,
        }));
    })
    .sort((a, b) => (b.ev ?? -999) - (a.ev ?? -999))
    .slice(0, 6);
}