ODDS_API_KEY=replace_with_your_real_odds_api_key
ODDS_API_REGIONS=us
ODDS_API_BOOKMAKERS=draftkings,fanduel,betmgm
ODDS_BOARD_PROVIDER=book_feeds
ODDS_BOARD_FALLBACKS=scraper_cache,oddsharvester
BOOK_FEED_DRAFTKINGS_SOURCE_URL=
BOOK_FEED_FANDUEL_SOURCE_URL=

# -----------------------------------------------------------------------
# TheRundown live board (Priority 3 fix)
# Set THERUNDOWN_API_KEY to enable the TheRundown board provider.
# Set THERUNDOWN_AFFILIATE_IDS to a comma-separated list of your affiliate
# IDs so book names show as real sportsbooks instead of "Affiliate 123".
# Example: THERUNDOWN_AFFILIATE_IDS=14,3,8
# -----------------------------------------------------------------------
THERUNDOWN_API_KEY=
THERUNDOWN_AFFILIATE_IDS=

# -----------------------------------------------------------------------
# Props scraper (backend/props_scraper.py)
# Scrapes player props from The Odds API without burning your IP.
# Uses legitimate API calls + rotating user agents + jittered delays.
# Set PROPS_POLL_INTERVAL_SECONDS to control how often it runs (default 300).
# -----------------------------------------------------------------------
PROPS_POLL_INTERVAL_SECONDS=300

# -----------------------------------------------------------------------
# IP protection for all scrapers
# Set PROXY_URL to route all HTTP requests through a residential proxy.
# Recommended: Bright Data, Oxylabs, or Smartproxy residential pool.
# Format: http://user:pass@proxy-host:port
# Without this, scrapers run from your server IP directly.
# -----------------------------------------------------------------------
PROXY_URL=

# -----------------------------------------------------------------------
# Book feed worker URLs (Priority 4 fix)
# Set these in Vercel environment variables to enable the DraftKings and
# FanDuel worker-only book feed paths. Without them the frontend falls back
# to the backend board endpoint automatically, but real per-book line data
# and named sportsbooks only appear when these are explicitly configured.
# Point each to your backend /api/book-feeds/<provider> endpoint.
# Example: SHARKEDGE_DRAFTKINGS_FEED_URL=https://your-backend.vercel.app/api/book-feeds/draftkings
# -----------------------------------------------------------------------
SHARKEDGE_DRAFTKINGS_FEED_URL=
SHARKEDGE_FANDUEL_FEED_URL=
BOOK_FEED_CACHE_SECONDS=90
BOOK_FEED_MAX_AGE_SECONDS=180
BOOK_FEED_TIMEOUT_SECONDS=20
PINNACLE_API_KEY=
PINNACLE_REQUEST_TIMEOUT_SECONDS=10
PINNACLE_CACHE_SECONDS=45
ODDSHARVESTER_COMMAND=oddsharvester
ODDSHARVESTER_HEADLESS=true
ODDSHARVESTER_TIMEOUT_SECONDS=120
ODDSHARVESTER_LEAGUES_BASKETBALL_NBA=usa-nba
ODDSHARVESTER_LEAGUES_BASKETBALL_NCAAB=usa-ncaa
ODDSHARVESTER_LEAGUES_BASEBALL_MLB=mlb
ODDSHARVESTER_LEAGUES_ICEHOCKEY_NHL=usa-nhl
ODDSHARVESTER_LEAGUES_AMERICANFOOTBALL_NFL=usa-nfl
ODDSHARVESTER_LEAGUES_AMERICANFOOTBALL_NCAAF=usa-ncaa
SHARKEDGE_API_KEY=replace_with_shared_ingest_key
SCRAPER_CACHE_MAX_AGE_SECONDS=180
POLL_INTERVAL_SECONDS=60
MAX_EVENTS_PER_SPORT=20
SPORTS_TO_SCRAPE=basketball,baseball,hockey,american-football,ufc,boxing
SPORTS_FILTERS=baseball:MLB,american-football:NFL|NCAAF,basketball:NBA|NCAAB,hockey:NHL
HEADLESS=true
PROXY_URL=
RUN_ONCE=false
